# Copy to `.env` in the project root (`.env` is gitignored).
# Used when `llm.provider: gemini` and `gemini.api_key_env` matches the variable name below.

GOOGLE_API_KEY=

# Used when `llm.provider: openai` and `openai.api_key_env` matches the variable name below.

OPENAI_API_KEY=

# Optional Google Drive service-account auth. Use names only here; never put
# private key JSON in committed files.
# GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=.secrets/google-drive-service-account.json
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
